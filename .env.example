# Environment Configuration

# FastAPI
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
DEBUG=True

# Neo4j (Future)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Liases Foras API (Future)
LIASES_FORAS_API_KEY=your_api_key_here
LF_DATA_VERSION=Q3_FY25

# Claude AI (Future)
CLAUDE_API_KEY=your_anthropic_api_key_here

# Google APIs for Context Panel (Maps, Images, News, Weather)
# ===============================================================

# Google Maps API
# Get from: https://console.cloud.google.com/google/maps-apis
# Enable APIs: Maps Static API, Maps Embed API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Custom Search API (for location images)
# Get API Key: https://console.cloud.google.com/apis/credentials
# Get Search Engine ID: https://programmablesearchengine.google.com/
# Enable API: Custom Search API
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here
GOOGLE_SEARCH_CX=your_custom_search_engine_id_here

# OpenWeather API (for weather data)
# Get from: https://openweathermap.org/api
# Free tier: 1000 calls/day
OPENWEATHER_API_KEY=your_openweather_api_key_here

# NewsAPI (for latest news)
# Get from: https://newsapi.org/
# Free tier: 100 requests/day
NEWS_API_KEY=your_news_api_key_here

# Data Sources
DATA_PATH=./data
MOCK_DATA_ENABLED=True

# Vector Database
CHROMA_DB_PATH=data/chroma_db
