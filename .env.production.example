# Production Environment Configuration
# Copy this file to .env.production when deploying to production

# FastAPI
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
DEBUG=False

# Neo4j
NEO4J_URI=bolt://your-production-neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_secure_production_password

# Liases Foras API
LIASES_FORAS_API_KEY=your_production_api_key_here
LF_DATA_VERSION=Q3_FY25

# Claude AI
CLAUDE_API_KEY=your_production_anthropic_api_key_here

# Google APIs for Context Panel
GOOGLE_MAPS_API_KEY=your_production_google_maps_api_key
GOOGLE_SEARCH_API_KEY=your_production_google_search_api_key
GOOGLE_SEARCH_CX=your_production_search_engine_id

# OpenWeather API
OPENWEATHER_API_KEY=your_production_openweather_api_key

# Data Sources
DATA_PATH=./data
MOCK_DATA_ENABLED=False

# Vector Database
CHROMA_DB_PATH=data/chroma_db

# Government of India Data APIs
GOV_IN_API_KEY=your_production_gov_api_key
GOV_IN_API_BASE_URL=https://api.data.gov.in

# NewsData.io API
NEWSDATA_API_KEY=your_production_newsdata_api_key
NEWSDATA_API_BASE_URL=https://newsdata.io/api/1

# LLM Provider Configuration
# ===============================================================
# Choose LLM provider: "ollama" (local) or "gemini" (cloud)
# Ollama = Free, local, no rate limits, requires Ollama running
# Gemini = Cloud-based, requires API key, subject to rate limits
LLM_PROVIDER=ollama

# Ollama Configuration (for local Qwen 2.5)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:latest

# Gemini Configuration (for cloud-based AI)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp

# QA Automation (CRITICAL: Keep disabled in production)
# ===============================================================
# NEVER enable QA Automation in production environments
# This feature is for internal testing only
ENABLE_QA_AUTOMATION=false
